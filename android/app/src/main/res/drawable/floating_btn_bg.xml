<?xml version="1.0" encoding="utf-8"?>
<!-- Floating button background: glowing cyan circle -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#2200E5FF" />
        </shape>
    </item>
    <!-- Main circle body -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="#F01A1A3A" />
            <stroke android:width="2.5dp" android:color="#FF00E5FF" />
        </shape>
    </item>
</layer-list>
