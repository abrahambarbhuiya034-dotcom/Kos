<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility service config for AIMxASSIST CarromBot v9.0.

    canPerformGestures="true"          — inject swipes via dispatchGesture()
    canRetrieveWindowContent="true"    — needed on some OEMs for stable gesture injection
    accessibilityFlags flagRequestEnhancedWebAccessibility — keeps service alive reliably
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeAllMask"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault|flagRequestEnhancedWebAccessibility"
    android:canPerformGestures="true"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity="com.bitaim.carromaim.MainActivity" />
